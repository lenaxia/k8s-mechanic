	c4 := newTestClient(thirdAgentObj)
	r.Client = c4

	// This should not create a RemediationJob (chain depth exceeds max)
	_, err = r.Reconcile(context.Background(), reqFor("mendabot-agent-ghi789", "default"))
	if err != nil {
		t.Fatalf("fourth reconcile (chain depth 3) failed: %v", err)
	}

	// Count total RemediationJobs created
	var list v1alpha1.RemediationJobList
	if err := c4.List(context.Background(), &list, client.InNamespace(agentNamespace)); err != nil {
		t.Fatalf("list error: %v", err)
	}

	// Should have 3 RemediationJobs: original job, first agent job, second agent job
	// Third agent job should be blocked (chain depth 3 > max depth 2)
	if len(list.Items) != 3 {
		t.Errorf("expected 3 RemediationJobs (chain depth 0,1,2), got %d", len(list.Items))
	}
}

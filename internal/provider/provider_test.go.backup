	}
}

// TestSourceProviderReconciler_FullCascadeFlow tests the full cascade flow simulation
func TestSourceProviderReconciler_FullCascadeFlow(t *testing.T) {
	// Simulate Job -> Finding -> RemediationJob -> Agent Job cascade

	// Step 1: Original Job fails
	jobFinding := &domain.Finding{
		Kind:         "Job",
		Name:         "original-job",
		Namespace:    "default",
		ParentObject: "Job/original-job",
		Errors:       `[{"text":"failed (3 attempts, 0 active)"}]`,
		ChainDepth:   0,
	}

	p := &fakeSourceProvider{
		name:       "native",
		objectType: &corev1.ConfigMap{},
		finding:    jobFinding,
	}

	obj := makeWatchedObject("original-job", "default")
	c := newTestClient(obj)
	r := newTestReconciler(p, c)

	// Create RemediationJob for original job
	_, err := r.Reconcile(context.Background(), reqFor("original-job", "default"))
	if err != nil {
		t.Fatalf("first reconcile failed: %v", err)
	}

	// Check first RemediationJob was created
	var list1 v1alpha1.RemediationJobList
	if err := c.List(context.Background(), &list1, &client.ListOptions{Namespace: agentNamespace}); err != nil {
		t.Fatalf("list error: %v", err)
	}
	if len(list1.Items) != 1 {
		t.Errorf("expected 1 RemediationJob after first failure, got %d", len(list1.Items))
	}

	// Step 2: Agent Job (created by RemediationJob) fails
	agentJobFinding := &domain.Finding{
		Kind:              "Job",
		Name:              "mendabot-agent-abc123",
		Namespace:         "default",
		ParentObject:      "Job/mendabot-agent-abc123",
		Errors:            `[{"text":"failed (1 attempts, 0 active)"}]`,
		IsSelfRemediation: true,
		ChainDepth:        1, // Incremented from 0
	}

	p.finding = agentJobFinding
	agentObj := makeWatchedObject("mendabot-agent-abc123", "default")
	c = newTestClient(agentObj, &list1.Items[0]) // Include existing RemediationJob
	r.Client = c

	// Create RemediationJob for agent job (self-remediation)
	_, err = r.Reconcile(context.Background(), reqFor("mendabot-agent-abc123", "default"))
	if err != nil {
		t.Fatalf("second reconcile (self-remediation) failed: %v", err)
	}

	// Check second RemediationJob was created
	var list2 v1alpha1.RemediationJobList
	if err := c.List(context.Background(), &list2, &client.ListOptions{Namespace: agentNamespace}); err != nil {
		t.Fatalf("list error: %v", err)
	}
	if len(list2.Items) != 2 {
		t.Errorf("expected 2 RemediationJobs after second failure, got %d", len(list2.Items))
	}

	// Step 3: Second agent Job fails (chain depth 2)
	secondAgentJobFinding := &domain.Finding{
		Kind:              "Job",
		Name:              "mendabot-agent-def456",
		Namespace:         "default",
		ParentObject:      "Job/mendabot-agent-def456",
		Errors:            `[{"text":"failed (1 attempts, 0 active)"}]`,
		IsSelfRemediation: true,
		ChainDepth:        2, // Incremented from 1
	}

	p.finding = secondAgentJobFinding
	secondAgentObj := makeWatchedObject("mendabot-agent-def456", "default")
	// Include all existing RemediationJobs
	var allObjects []client.Object
	allObjects = append(allObjects, secondAgentObj)
	for i := range list2.Items {
		allObjects = append(allObjects, &list2.Items[i])
	}
	c = newTestClient(allObjects...)
	r.Client = c

	// With default max depth 2, this should create a RemediationJob
	_, err = r.Reconcile(context.Background(), reqFor("mendabot-agent-def456", "default"))
	if err != nil {
		t.Fatalf("third reconcile (chain depth 2) failed: %v", err)
	}

	// Check third RemediationJob was created
	var list3 v1alpha1.RemediationJobList
	if err := c.List(context.Background(), &list3, &client.ListOptions{Namespace: agentNamespace}); err != nil {
		t.Fatalf("list error: %v", err)
	}
	if len(list3.Items) != 3 {
		t.Errorf("expected 3 RemediationJobs after third failure (chain depth 2), got %d", len(list3.Items))
	}

	// Step 4: Third agent Job fails (chain depth 3) - should be blocked
	thirdAgentJobFinding := &domain.Finding{
		Kind:              "Job",
		Name:              "mendabot-agent-ghi789",
		Namespace:         "default",
		ParentObject:      "Job/mendabot-agent-ghi789",
		Errors:            `[{"text":"failed (1 attempts, 0 active)"}]`,
		IsSelfRemediation: true,
		ChainDepth:        3, // Exceeds max depth 2
	}

	p.finding = thirdAgentJobFinding
	thirdAgentObj := makeWatchedObject("mendabot-agent-ghi789", "default")
	// Include all existing RemediationJobs
	allObjects = []client.Object{thirdAgentObj}
	for i := range list3.Items {
		allObjects = append(allObjects, &list3.Items[i])
	}
	c = newTestClient(allObjects...)
	r.Client = c

	// This should not create a RemediationJob (chain depth exceeds max)
	_, err = r.Reconcile(context.Background(), reqFor("mendabot-agent-ghi789", "default"))
	if err != nil {
		t.Fatalf("fourth reconcile (chain depth 3) failed: %v", err)
	}

	// Check no new RemediationJob was created
	var list4 v1alpha1.RemediationJobList
	if err := c.List(context.Background(), &list4, &client.ListOptions{Namespace: agentNamespace}); err != nil {
		t.Fatalf("list error: %v", err)
	}
	if len(list4.Items) != 3 {
		t.Errorf("expected still 3 RemediationJobs after fourth failure (chain depth 3 exceeds max), got %d", len(list4.Items))
	}

	// Use a single client to accumulate all RemediationJobs
	var allObjects []client.Object
	obj := makeWatchedObject("original-job", "default")
	allObjects = append(allObjects, obj)
	client := newTestClient(allObjects...)
	reconciler := newTestReconciler(p, client)

	// Create RemediationJob for original job
	_, err := reconciler.Reconcile(context.Background(), reqFor("original-job", "default"))
	if err != nil {
		t.Fatalf("first reconcile failed: %v", err)
	}

	// Step 2: Agent Job (created by RemediationJob) fails
	agentJobFinding := &domain.Finding{
		Kind:              "Job",
		Name:              "mendabot-agent-abc123",
		Namespace:         "default",
		ParentObject:      "Job/mendabot-agent-abc123",
		Errors:            `[{"text":"failed (1 attempts, 0 active)"}]`,
		IsSelfRemediation: true,
		ChainDepth:        1, // Incremented from 0
	}

	p.finding = agentJobFinding
	agentObj := makeWatchedObject("mendabot-agent-abc123", "default")
	allObjects = append(allObjects, agentObj)
	client = newTestClient(allObjects...)
	reconciler.Client = client

	// Create RemediationJob for agent job (self-remediation)
	_, err = reconciler.Reconcile(context.Background(), reqFor("mendabot-agent-abc123", "default"))
	if err != nil {
		t.Fatalf("second reconcile (self-remediation) failed: %v", err)
	}

	// Step 3: Second agent Job fails (chain depth 2)
	secondAgentJobFinding := &domain.Finding{
		Kind:              "Job",
		Name:              "mendabot-agent-def456",
		Namespace:         "default",
		ParentObject:      "Job/mendabot-agent-def456",
		Errors:            `[{"text":"failed (1 attempts, 0 active)"}]`,
		IsSelfRemediation: true,
		ChainDepth:        2, // Incremented from 1
	}

	p.finding = secondAgentJobFinding
	secondAgentObj := makeWatchedObject("mendabot-agent-def456", "default")
	allObjects = append(allObjects, secondAgentObj)
	client = newTestClient(allObjects...)
	reconciler.Client = client

	// With default max depth 2, this should create a RemediationJob
	_, err = reconciler.Reconcile(context.Background(), reqFor("mendabot-agent-def456", "default"))
	if err != nil {
		t.Fatalf("third reconcile (chain depth 2) failed: %v", err)
	}

	// Step 4: Third agent Job fails (chain depth 3) - should be blocked
	thirdAgentJobFinding := &domain.Finding{
		Kind:              "Job",
		Name:              "mendabot-agent-ghi789",
		Namespace:         "default",
		ParentObject:      "Job/mendabot-agent-ghi789",
		Errors:            `[{"text":"failed (1 attempts, 0 active)"}]`,
		IsSelfRemediation: true,
		ChainDepth:        3, // Exceeds max depth 2
	}

	p.finding = thirdAgentJobFinding
	thirdAgentObj := makeWatchedObject("mendabot-agent-ghi789", "default")
	allObjects = append(allObjects, thirdAgentObj)
	client = newTestClient(allObjects...)
	reconciler.Client = client

	// This should not create a RemediationJob (chain depth exceeds max)
	_, err = reconciler.Reconcile(context.Background(), reqFor("mendabot-agent-ghi789", "default"))
	if err != nil {
		t.Fatalf("fourth reconcile (chain depth 3) failed: %v", err)
	}

	// Count total RemediationJobs created
	var rjobList v1alpha1.RemediationJobList
	if err := client.List(context.Background(), &rjobList, client.InNamespace(agentNamespace)); err != nil {
		t.Fatalf("list error: %v", err)
	}

	// Should have 3 RemediationJobs: original job, first agent job, second agent job
	// Third agent job should be blocked (chain depth 3 > max depth 2)
	if len(rjobList.Items) != 3 {
		t.Errorf("expected 3 RemediationJobs (chain depth 0,1,2), got %d", len(rjobList.Items))
	}

	// Step 2: Agent Job (created by RemediationJob) fails
	agentJobFinding := &domain.Finding{
		Kind:              "Job",
		Name:              "mendabot-agent-abc123",
		Namespace:         "default",
		ParentObject:      "Job/mendabot-agent-abc123",
		Errors:            `[{"text":"failed (1 attempts, 0 active)"}]`,
		IsSelfRemediation: true,
		ChainDepth:        1, // Incremented from 0
	}

	p.finding = agentJobFinding
	agentObj := makeWatchedObject("mendabot-agent-abc123", "default")
	allObjects = append(allObjects, agentObj)
	c = newTestClient(allObjects...)
	r.Client = c

	// Create RemediationJob for agent job (self-remediation)
	_, err = r.Reconcile(context.Background(), reqFor("mendabot-agent-abc123", "default"))
	if err != nil {
		t.Fatalf("second reconcile (self-remediation) failed: %v", err)
	}

	// Step 3: Second agent Job fails (chain depth 2)
	secondAgentJobFinding := &domain.Finding{
		Kind:              "Job",
		Name:              "mendabot-agent-def456",
		Namespace:         "default",
		ParentObject:      "Job/mendabot-agent-def456",
		Errors:            `[{"text":"failed (1 attempts, 0 active)"}]`,
		IsSelfRemediation: true,
		ChainDepth:        2, // Incremented from 1
	}

	p.finding = secondAgentJobFinding
	secondAgentObj := makeWatchedObject("mendabot-agent-def456", "default")
	allObjects = append(allObjects, secondAgentObj)
	c = newTestClient(allObjects...)
	r.Client = c

	// With default max depth 2, this should create a RemediationJob
	_, err = r.Reconcile(context.Background(), reqFor("mendabot-agent-def456", "default"))
	if err != nil {
		t.Fatalf("third reconcile (chain depth 2) failed: %v", err)
	}

	// Step 4: Third agent Job fails (chain depth 3) - should be blocked
	thirdAgentJobFinding := &domain.Finding{
		Kind:              "Job",
		Name:              "mendabot-agent-ghi789",
		Namespace:         "default",
		ParentObject:      "Job/mendabot-agent-ghi789",
		Errors:            `[{"text":"failed (1 attempts, 0 active)"}]`,
		IsSelfRemediation: true,
		ChainDepth:        3, // Exceeds max depth 2
	}

	p.finding = thirdAgentJobFinding
	thirdAgentObj := makeWatchedObject("mendabot-agent-ghi789", "default")
	allObjects = append(allObjects, thirdAgentObj)
	c = newTestClient(allObjects...)
	r.Client = c

	// This should not create a RemediationJob (chain depth exceeds max)
	_, err = r.Reconcile(context.Background(), reqFor("mendabot-agent-ghi789", "default"))
	if err != nil {
		t.Fatalf("fourth reconcile (chain depth 3) failed: %v", err)
	}

	// Count total RemediationJobs created
	var list v1alpha1.RemediationJobList
	if err := c.List(context.Background(), &list, client.InNamespace(agentNamespace)); err != nil {
		t.Fatalf("list error: %v", err)
	}

	// Should have 3 RemediationJobs: original job, first agent job, second agent job
	// Third agent job should be blocked (chain depth 3 > max depth 2)
	if len(list.Items) != 3 {
		t.Errorf("expected 3 RemediationJobs (chain depth 0,1,2), got %d", len(list.Items))
	}

	// Step 2: Agent Job (created by RemediationJob) fails
	agentJobFinding := &domain.Finding{
		Kind:              "Job",
		Name:              "mendabot-agent-abc123",
		Namespace:         "default",
		ParentObject:      "Job/mendabot-agent-abc123",
		Errors:            `[{"text":"failed (1 attempts, 0 active)"}]`,
		IsSelfRemediation: true,
		ChainDepth:        1, // Incremented from 0
	}

	p.finding = agentJobFinding
	agentObj := makeWatchedObject("mendabot-agent-abc123", "default")
	c2 := newTestClient(agentObj)
	r.Client = c2

	// Create RemediationJob for agent job (self-remediation)
	_, err = r.Reconcile(context.Background(), reqFor("mendabot-agent-abc123", "default"))
	if err != nil {
		t.Fatalf("second reconcile (self-remediation) failed: %v", err)
	}

	// Step 3: Second agent Job fails (chain depth 2)
